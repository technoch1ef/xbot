# X.com (Twitter) API credentials (OAuth 1.0a user context) — all required
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Numeric user ID of the bot account (NOT its @handle). Used to read the
# mentions timeline and to skip the bot's own tweets. Required.
BOT_USER_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Sampling temperature, 0–2.
OPENAI_TEMPERATURE=0.7

# Bot behavior
# Seconds between mention polls.
POLL_INTERVAL_SEC=300
# Cap on replies posted per poll cycle.
MAX_REPLIES_PER_RUN=5
# When true, generate replies but do NOT post them.
# Accepts true/false, 1/0, yes/no, on/off.
DRY_RUN=false

# Persona — set EXACTLY ONE of the following (startup fails if neither, and an
# empty value still counts as "set"). PERSONA_PROMPT is an inline system prompt;
# PERSONA_PROMPT_PATH points at a file. The default below uses the bundled file;
# to use an inline prompt instead, uncomment PERSONA_PROMPT and remove the path.
#PERSONA_PROMPT=
PERSONA_PROMPT_PATH=prompts/persona.md

# Inbound mention filtering (optional)
# Comma-separated user IDs and/or @handles to never reply to.
BLOCKLIST=
# Comma-separated BCP-47 language codes to allow (e.g. en,es). Empty = allow all.
ALLOWED_LANGUAGES=

# Persistence
# SQLite file for the cursor + reply-dedupe store.
DATABASE_PATH=./xbot.db

# HTTP server (health checks + optional webhook receiver)
PORT=3000
HOST=0.0.0.0

# Optional Account Activity API (AAA) webhook receiver (Enterprise-only).
# Off by default; the poller is the sole ingestion path unless enabled.
WEBHOOK_ENABLED=false
WEBHOOK_PATH=/webhook/twitter

# Logging — read directly by the logger (src/index.ts), defaults to "info".
LOG_LEVEL=info

# Runtime — when set to "production", the app does NOT read a local .env file
# and relies on the injected environment instead (src/config.ts).
NODE_ENV=development
