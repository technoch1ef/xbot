# X.com (Twitter) API credentials (OAuth 1.0a user context)
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# X.com API v2 bearer (app-only, for read endpoints)
X_BEARER_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Bot behavior
BOT_HANDLE=
SEARCH_QUERY=crypto
POLL_CRON=*/5 * * * *
MAX_REPLIES_PER_RUN=5

# Inbound mention filtering (optional)
# Comma-separated user IDs and/or @handles to never reply to.
BLOCKLIST=
# Comma-separated BCP-47 language codes to allow (e.g. en,es). Empty = allow all.
ALLOWED_LANGUAGES=

# Persistence
DATABASE_PATH=./xbot.db

# HTTP server (health checks)
PORT=3000
HOST=0.0.0.0

# Logging
LOG_LEVEL=info

# Runtime
NODE_ENV=development
